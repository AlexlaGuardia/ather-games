  ornate_chest: ['#d544c8', '#5a3a10', '#f0e6c8', '#1a1a2e', '#d06040', '#50a040', '#4080c0', '#8060b0'],
  moss_chest: ['#d544c8', '#5a3a10', '#f0e6c8', '#1a1a2e', '#d06040', '#50a040', '#4080c0', '#8060b0'],
  crystal_chest: ['#d544c8', '#5a3a10', '#f0e6c8', '#1a1a2e', '#d06040', '#50a040', '#4080c0', '#8060b0'],
  shadow_chest: ['#d544c8', '#5a3a10', '#f0e6c8', '#1a1a2e', '#d06040', '#50a040', '#4080c0', '#8060b0'],
  alchemy_table: ['#d544c8', '#5a3a10', '#f0e6c8', '#1a1a2e', '#d06040', '#50a040', '#4080c0', '#8060b0'],
  exchange_booth: ['#d544c8', '#5a3a10', '#f0e6c8', '#1a1a2e', '#d06040', '#50a040', '#4080c0', '#8060b0'],
}

const S = 32

// ============================================
// Furniture definitions
// ============================================

export interface FurnitureDef {
  id: string
  name: string
  description: string
  price: number              // Marks to buy from Gregory
  interactionPanel: string   // which sidePanel to open on interact
  stackable: boolean
  maxStack: number
  chestSlots?: number        // storage capacity (only for chest-type furniture)
  recipe?: { itemId: string; count: number }[]  // crafting recipe (if craftable)
}

