// Furniture system — definitions + 16x16 pixel art icons
// Placeable world objects with interactions (chest, crafting table, etc.)
// Each furniture piece has its own palette (max 14 colors, 0=transparent, 1-14=palette index)

import { px, SpriteAnim } from './sprite-data'
export { ITEM_PALETTE as FURNITURE_PALETTE } from './items'

// Per-furniture palettes — each id gets its own colors (0=transparent, 1-N=palette index, max 14)
// Items without an entry here fall back to ITEM_PALETTE in the renderer
export const FURNITURE_PALETTES: Record<string, string[]> = {
  crafting_table: ['#57390f', '#704a15', '#c9af97', '#1a1a2e', '#d06040', '#1d3f58', '#7a7171', '#917f6e'],
  chest: ['#7a521a', '#5a3a10', '#f0e6c8', '#1a1a2e', '#766a2e', '#454c43', '#4080c0', '#8060b0'],
